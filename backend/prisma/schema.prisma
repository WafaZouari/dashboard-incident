generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int            @id @default(autoincrement())
  email                   String         @unique
  passwordHash            String         @map("password_hash")
  firstName               String?        @map("first_name")
  lastName                String?        @map("last_name")
  role                    String
  department              String?
  isActive                Boolean        @default(true) @map("is_active")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  createdIncidents        Incident[]     @relation("CreatedBy")
  assignedActionItems     ActionItem[]   @relation("AssignedTo")
  investigations          Investigation[]
  uploadedAttachments     Attachment[]

  @@map("users")
}

model Incident {
  id                      Int            @id @default(autoincrement())
  sourceYear              Int?           @map("source_year")
  incidentNo              String         @unique @map("incident_no")
  reportedBy              String?        @map("reported_by")
  site                    String?
  locationOnSite          String?        @map("location_on_site")
  dateTimeOccurred        DateTime?      @map("date_time_occurred")
  pearClass               String?        @map("pear_class")
  subCategory             String?        @map("sub_category")
  briefDescription        String?        @db.Text @map("brief_description")
  incTypeIfInjury         String?        @map("inc_type_if_injury")
  assetIntegrityType      String?        @map("asset_integrity_type")
  damagedZone             String?        @map("damaged_zone")
  pseTiers                String?        @map("pse_tiers")
  actualSeverity          Int?           @map("actual_severity")
  potentialSeverity       Int?           @map("potential_severity")
  investigationDone       Boolean        @default(false) @map("investigation_done")

  status                  String         @default("open")
  createdById             Int?           @map("created_by_id")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  createdBy               User?          @relation("CreatedBy", fields: [createdById], references: [id])
  investigations          Investigation[]
  actionItems             ActionItem[]
  attachments             Attachment[]

  @@index([dateTimeOccurred])
  @@index([status])
  @@index([actualSeverity])
  @@map("incidents")
}

model Investigation {
  id                Int          @id @default(autoincrement())
  incidentId        Int          @map("incident_id")
  investigationDate DateTime?    @map("investigation_date")
  investigatorId    Int?         @map("investigator_id")
  immediateCauses   String?      @map("immediate_causes") @db.Text
  rootCauses        String?      @map("root_causes") @db.Text
  findings          String?      @db.Text
  recommendations   String?      @db.Text
  status            String       @default("pending")
  completedAt       DateTime?    @map("completed_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  incident          Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  investigator      User?        @relation(fields: [investigatorId], references: [id])
  actionItems       ActionItem[]

  @@map("investigations")
}

model ActionItem {
  id                         Int            @id @default(autoincrement())
  incidentId                 Int            @map("incident_id")
  investigationId            Int?           @map("investigation_id")
  correctiveActionsTaken     String?        @map("corrective_actions_taken") @db.Text
  suggestionsRecommendations String?        @map("suggestions_recommendations") @db.Text
  assignedToId               Int?           @map("assigned_to_id")
  dueDate                    DateTime?      @map("due_date")
  status                     String         @default("pending")
  priority                   String         @default("medium")
  completedAt                DateTime?      @map("completed_at")
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")

  incident                   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  investigation              Investigation? @relation(fields: [investigationId], references: [id])
  assignedTo                 User?          @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@map("action_items")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  incidentId  Int      @map("incident_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileType    String?  @map("file_type")
  fileSize    Int?     @map("file_size")
  uploadedById Int?    @map("uploaded_by_id")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}
